GATEWAY_PUBLIC_KEY=GB7THTEVT2T7CZQ5TFUOIQSI32XCJ7BHWS35OBTAI2V4FNL7BXZZ2GM2

# Gateway fee percentage (0.15 = 15%)
GATEWAY_FEE_PERCENT=0.15

# ── Server ───────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── Database (Supabase) ───────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# ── External APIs (for tools) ────────────────────────────
# CoinGecko (free tier, no key needed for basic use)
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Etherscan (free API key at etherscan.io)
ETHERSCAN_API_KEY=your-etherscan-key

# ── OpenAI (for LangGraph agent) ─────────────────────────
OPENAI_API_KEY=sk-...

